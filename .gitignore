# ============================================================
# GenAI Research Platform — .gitignore
# ============================================================
# This file tells Git which files/dirs to NEVER commit.
# Critical for security (no .env, no API keys) and cleanliness
# (no __pycache__, no build artifacts).
# ============================================================

# ---- Secrets & environment files ----
# NEVER commit .env files — they may contain real API keys.
.env
.env.local
.env.*.local
.env.production
.env.development
# Note: .env.template and .env.example ARE committed (they hold placeholders only).

# ---- Python bytecode & caches ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Distribution / packaging ----
build/
dist/
*.egg-info/
*.egg
.eggs/
sdist/
wheels/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.python-version

# ---- Test & coverage artifacts ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ---- IDE / editor files ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Logs ----
*.log
logs/
*.out

# ---- Project-specific runtime artifacts ----
# Uploaded PDFs / Excel files from users (route: /api/network, /api/extract/*)
backend/uploads/
backend/tmp/

# ChemExtract on-disk cache (regenerated per-run from PDF content hashes)
/tmp/chemextract_cache/
chemextract_cache/

# Duplicate data archive (the unzipped nicobot_data/ folder is the source of truth)
backend/nicobot_data.zip

# ---- OS / misc ----
*.bak
*.tmp
*.swp
*~
.DS_Store
.AppleDouble
.LSOverride
._*

# ---- Type-checker caches ----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ---- Lint caches ----
.ruff_cache/
.cache/
