{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Flask Server",
            "type": "shell",
            "command": "python",
            "args": ["backend/app.py"],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Install Dependencies",
            "type": "shell",
            "command": "pip",
            "args": ["install", "-r", "backend/requirements.txt"],
            "problemMatcher": []
        }
    ]
}
