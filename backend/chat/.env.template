# ============================================================
# Environment Variables Template for GenAI Research Platform
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control!

# ============================================================
# Application Configuration
# ============================================================
# Secret key for session security (generate a random string)
SECRET_KEY=your-secret-key-here-change-in-production

# Flask environment (development, production, testing)
FLASK_ENV=development

# ============================================================
# CORS Configuration
# ============================================================
# Allowed origins for CORS, separated by commas
# For production, add your domain(s) here
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:3000

# ============================================================
# Rate Limiting
# ============================================================
# Verify backend API keys on startup (set to true to test connections)
VERIFY_BACKEND_KEYS=false

# ============================================================
# LLM Configuration (OPTIONAL - Users provide their own keys)
# ============================================================
# If you want to set a default provider for all users, uncomment below:
# LLM_PROVIDER=deepseek

# NOTE: Users will provide their own API keys through the web interface
# when using LLM-powered features (Knowledge Graph, Explanations, etc.)
# 
# Supported providers: deepseek, openai, groq, gemini, huggingface, openrouter, ollama
# - Groq: https://console.groq.com (FREE tier available)
# - Gemini: https://ai.google.dev (FREE tier available)
# - DeepSeek: https://platform.deepseek.com
# - OpenAI: https://platform.openai.com
# - OpenRouter: https://openrouter.ai (Multiple models, some free)
# - HuggingFace: https://huggingface.co/settings/tokens (FREE)
# - Ollama: https://ollama.ai (100% FREE, runs locally)

# ============================================================
# Optional: Caching Configuration
# ============================================================
# Redis URL for production caching (optional)
# REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 3600 = 1 hour)
# CACHE_TTL=3600

# ============================================================
# Optional: Database Configuration
# ============================================================
# DATABASE_URL=postgresql://user:password@localhost/dbname

# ============================================================
# LLM API Keys (Optional - for backend defaults)
# ============================================================
# Uncomment and add your API keys if you want backend-level configuration
# These are optional - users can provide their own keys via the UI

# Groq (FREE tier available)
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (FREE tier available)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Hugging Face (FREE)
# HF_API_KEY=your-huggingface-api-key
# HF_MODEL=meta-llama/Llama-3.2-3B-Instruct

# OpenRouter
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# Ollama (Local, FREE)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
